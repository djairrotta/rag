# Build a partir da RAIZ do repo (contexto = repo). Serve para:
#  - EasyPanel App tipo Dockerfile: campo "File" = Dockerfile.rag
#  - docker compose: build.context=. / build.dockerfile=Dockerfile.rag
FROM python:3.12-slim
WORKDIR /app
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1
COPY rag/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY rag/app ./app
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
